@page "/"
@using Microsoft.AspNetCore.Authorization
@using Web.WebComponent
@attribute [Authorize]

<h1>Hello, world!</h1>

Welcome to your new app.

<div class="card">
    <div class="card-body">
        <Web.WebComponent.Treeview Nodes="treeData" OnOk="HandleOk" ShowSelectButton=true/>

    </div>
</div>

<input type="text" value="@selectedText" class="form-control" />



@code {

    string selectedText = "";

    List<TreeNode> treeData = new()
    {
        new TreeNode
        {
            Description = "Parent 1",
            IsExpanded = true,
            Children = new List<TreeNode>
            {
                new TreeNode { Description = "Child 1-1", IsChecked = true },
                new TreeNode { Description = "Child 1-2", IsChecked = true },
                new TreeNode
                {
                    Description = "Child 1-3",
                    Children = new List<TreeNode>
                    {
                        new TreeNode { Description = "Sub Child 1-3-1", IsChecked = true }
                    }
                }
            }
        },
        new TreeNode
        {
            Description = "Parent 2",
            Children = new List<TreeNode>
            {
                new TreeNode { Description = "Child 2-1" }
            }
        }
    };

    void HandleOk(List<TreeNode> checkedNodes)
    {
        foreach (var item in checkedNodes)
        {
            selectedText = string.Join(", ", checkedNodes.Select(x => x.Description));
        }
    }

   

  

}
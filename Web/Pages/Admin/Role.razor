@page "/role"
@using ApplicationLayer.DTOs
@using ApplicationLayer.RequestModel
@using ApplicationLayer.RequestModel.Admin
@using ApplicationLayer.Services.Admin
@using Microsoft.AspNetCore.Authorization
@using Web.WebComponent
@inject IRole roleSerivce
@inject IMenu menus
@inject IRolePermissionService rolePermissionService

@attribute [Authorize]

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Role Entry</h3>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-8">
                        <input type="text" class="form-control" @bind="@roleRequest.RoleName" />
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-success btn-sm" @onclick="Add">Save</button>
                        <button class="btn btn-secondary btn-sm" @onclick="Cancel">Cancel</button>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-12">
                        <Paging TItem="RoleDto"
                                Items="roleDtos"
                                PageSize="5"
                                ShowRowNumber="true"
                                EnableSearch="true"
                                ListingName="Role Listing"
                                OnEdit="EditRole"
                                OnDetail = "Detail"
                                OnDelete="DeleteRole"
                                Columns="GridColumns">
                                
                        </Paging>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Menu Listing</h3>
            </div>
            <div class="card-body">
                <input type="text" class="form-control" @bind="@RoleName" disabled="true"/> <br />
                <Treeview Nodes="treeNodes" ShowSelectButton=true IsShowCheckBox=true OnOk="OnNodeClick" />
            </div>
        </div>


    </div>


</div>


@code {

    List<TreeNode> treeNodes = new();
    string RoleID = string.Empty;
    string RoleName = string.Empty;


    private RoleRequest roleRequest = new();
    private RoleDto roleDto = new();
    private List<RoleDto> roleDtos = new();

    private List<ColumnDefinition<RoleDto>> GridColumns = new()
    {
        new ColumnDefinition<RoleDto>
        {
            Title = "Name",
            PropertyName = nameof(RoleDto.RoleName),
            CellTemplate = e => e.RoleName
        },

    };

    private async void OnNodeClick(List<TreeNode> treeNodes)
    {

        foreach (var item in treeNodes)
        {
            RolePermissionRequest rolePermissionRequest = new RolePermissionRequest();
            rolePermissionRequest.RoleID = RoleID;
            rolePermissionRequest.MenuID = item.ID;
            rolePermissionRequest.RoleName = RoleName;
            rolePermissionRequest.IsAllowed = true;

            var (flag, message) = await rolePermissionService.AddAsync(rolePermissionRequest);
            if (!flag)
            {
                await JS.InvokeVoidAsync("showAlert", "error", "Failed!", message);
                return;
            }
            else
            {
                await JS.InvokeVoidAsync("showAlert", "success", "Saved!", "Your data has been saved.");
                roleDtos = await roleSerivce.GetAllAsync();
                roleRequest = new();

                StateHasChanged();
            }
            
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Fetch employee list from API
        roleDtos = await roleSerivce.GetAllAsync();
        var menu = await menus.GetAllAsync();
        treeNodes = MapToTreeNode(menu);
    }



    private async void Add()
    {
        var (flag, message) = await roleSerivce.AddAsync(roleRequest);
        if (!flag)
        {
            await JS.InvokeVoidAsync("showAlert", "error", "Failed!", message);
            return;
        }
        else
        {
            await JS.InvokeVoidAsync("showAlert", "success", "Saved!", "Your data has been saved.");
            roleDtos = await roleSerivce.GetAllAsync();
            roleRequest = new();

            StateHasChanged();
        }
    }

    private void Cancel()
    {
        // Logic to clear the input fields
    }

    private async Task EditRole(RoleDto roleDto)
    {
       
    }

    private async Task Detail(RoleDto roleDto)
    {
        RoleID = roleDto.RoleID;
        RoleName = roleDto.RoleName;
    }

    private async Task DeleteRole(RoleDto roleDto)
    {

    }

    List<TreeNode> MapToTreeNode(List<MenuDto> menus)
    {
        return menus.Select(menu => new TreeNode
        {
            ID = menu.MenuID,
            Code = menu.ControllerName,
            Description = menu.MenuName,
            ParentID = menu.ParentId,
            Children = menu.Children != null && menu.Children.Any()
                ? MapToTreeNode(menu.Children)
                : new List<TreeNode>()
        }).ToList();
    }


}
